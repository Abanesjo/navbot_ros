<?xml version="1.0"?>
<launch>
    <!-- Arguments -->
     <arg name="rviz" default="false"/>
     <arg name="rviz_config" default="$(find-pkg-share navbot_ros)/config/navbot.rviz"/>

    <!-- Static Transforms -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="base_to_aruco_tf" args="0 0 0 0 0 0 base_link aruco_frame"/>
    <node pkg="tf2_ros" exec="static_transform_publisher" name="base_to_laser_tf" args="0 0 0 0 0 0 base_link laser_frame"/>

    <node name="joy" pkg="joy" exec="joy_node"/>
    <node name="bringup" pkg="navbot_ros" exec="robot_ros_node.py"/>

    <node name="slam_toolbox" pkg="slam_toolbox" exec="sync_slam_toolbox_node" output="screen">
        <param name="odom_frame" value="odom"/>
        <param name="map_frame" value="map"/>
        <param name="base_frame" value="base_link"/>
        <param name="scan_topic" value="/scan"/>
        <param name="use_sim_time" value="false"/>
        <param name="mode" value="mapping"/>
    </node>

    <node name="odom_tf_publisher" pkg="navbot_ros" exec="odom_tf_publisher.py"/>

    <node name="guides" pkg="navbot_ros" exec="publish_guides.py"/>
    <node name="path_publisher" pkg="navbot_ros" exec="path_publisher.py"/>

    <group if="$(var rviz)">
        <node name="rviz" pkg="rviz2" exec="rviz2" args="-d $(var rviz_config)"/>
    </group>

    <node name="path_publisher" pkg="navbot_ros" exec="path_publisher.py"/>
</launch>